# Vitality Base Model — environment variables.
#
# Copy this file to `.env.local` (gitignored) and fill in your own values.
# Everything here comes from ONE free Supabase project — no other service is
# required to run the base.

# --- Supabase (required) ---
# Create a free project at https://supabase.com, then:
#   Project Settings → API
#     • Project URL            → NEXT_PUBLIC_SUPABASE_URL
#     • Project API keys: anon  → NEXT_PUBLIC_SUPABASE_ANON_KEY  (safe in the browser)
#     • Project API keys: service_role → SUPABASE_SERVICE_ROLE_KEY
#         (server-only — NEVER commit it, NEVER expose it to the client)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- App base URL (required) ---
# The absolute origin of this deployment. Used to build the OAuth return URL.
#   Local dev → http://localhost:3000
#   Vercel    → https://<your-project>.vercel.app  (or your custom domain)
NEXT_PUBLIC_APP_URL=http://localhost:3000
