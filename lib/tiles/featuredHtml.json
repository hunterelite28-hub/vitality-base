{
  "water-daily": "<!doctype html><html lang=\"en\"><head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1,viewport-fit=cover\">\n<title>Water</title>\n<style>\n  *{box-sizing:border-box}\n  html,body{height:100%}\n  body{background:transparent;color:#fff;font-family:-apple-system,BlinkMacSystemFont,'Inter','Segoe UI',sans-serif;accent-color:#6EE7B7;margin:0;-webkit-font-smoothing:antialiased}\n  ::selection{background:rgba(110,231,183,.3)}\n  .wrap{\n    display:flex;flex-direction:column;align-items:center;justify-content:center;\n    gap:clamp(8px,3vw,28px);\n    padding:clamp(12px,4vw,40px);\n    min-height:100%;\n    width:100%;\n    text-align:center;\n    overflow:auto;\n  }\n  .head{display:flex;flex-direction:column;align-items:center;gap:4px;flex:0 0 auto}\n  .label{\n    font-size:clamp(10px,2.6vw,13px);\n    letter-spacing:.14em;text-transform:uppercase;\n    color:rgba(255,255,255,.5);font-weight:600;\n  }\n  .sub{\n    font-size:clamp(11px,3vw,14px);\n    color:rgba(255,255,255,.42);font-weight:500;\n    transition:color .5s cubic-bezier(.16,1,.3,1);\n  }\n  .sub.done{color:#6EE7B7}\n\n  .ringwrap{\n    position:relative;\n    width:clamp(110px,42vw,260px);\n    height:clamp(110px,42vw,260px);\n    flex:0 1 auto;\n  }\n  svg.ring{width:100%;height:100%;display:block;transform:rotate(-90deg)}\n  .track{stroke:rgba(255,255,255,.08);fill:none}\n  .prog{\n    stroke:url(#mintgrad);fill:none;stroke-linecap:round;\n    transition:stroke-dashoffset .7s cubic-bezier(.16,1,.3,1),filter .6s cubic-bezier(.16,1,.3,1);\n  }\n  .ringwrap.done .prog{filter:drop-shadow(0 0 10px rgba(110,231,183,.65))}\n\n  /* filling wave inside the ring */\n  .core{\n    position:absolute;inset:clamp(9px,3.2vw,20px);\n    border-radius:50%;overflow:hidden;\n    display:flex;align-items:center;justify-content:center;\n    background:rgba(255,255,255,.025);\n  }\n  .fill{\n    position:absolute;left:-25%;right:-25%;bottom:0;\n    height:140%;\n    transition:transform .85s cubic-bezier(.16,1,.3,1);\n    transform:translateY(100%);\n  }\n  .fill .water{\n    position:absolute;left:0;right:0;bottom:0;top:18px;\n    background:linear-gradient(180deg,rgba(110,231,183,.34),rgba(110,231,183,.16));\n  }\n  .fill svg{position:absolute;left:0;bottom:calc(100% - 19px);width:200%;height:24px}\n  .wave-a{animation:drift 7s linear infinite}\n  .wave-b{animation:drift 11s linear infinite reverse;opacity:.55}\n  @keyframes drift{to{transform:translateX(-50%)}}\n  .ringwrap.done .water{background:linear-gradient(180deg,rgba(110,231,183,.5),rgba(110,231,183,.26))}\n\n  .count{\n    position:relative;z-index:2;\n    display:flex;flex-direction:column;align-items:center;line-height:1;\n  }\n  .num{\n    font-size:clamp(34px,14vw,92px);font-weight:700;\n    letter-spacing:-.03em;\n    font-variant-numeric:tabular-nums;\n    transition:transform .5s cubic-bezier(.16,1,.3,1);\n  }\n  .num.pop{transform:scale(1.12)}\n  .of{\n    font-size:clamp(10px,2.8vw,15px);\n    color:rgba(255,255,255,.5);font-weight:600;margin-top:5px;\n  }\n\n  .controls{display:flex;align-items:center;gap:clamp(12px,4vw,24px);flex:0 0 auto}\n  button.btn{\n    -webkit-appearance:none;appearance:none;cursor:pointer;\n    width:clamp(46px,14vw,72px);height:clamp(46px,14vw,72px);\n    border-radius:50%;\n    background:rgba(255,255,255,.06);\n    border:1px solid rgba(255,255,255,.12);\n    color:#fff;\n    display:flex;align-items:center;justify-content:center;\n    transition:transform .3s cubic-bezier(.16,1,.3,1),background .3s cubic-bezier(.16,1,.3,1),border-color .3s cubic-bezier(.16,1,.3,1),opacity .3s ease;\n    -webkit-tap-highlight-color:transparent;\n    flex:0 0 auto;\n  }\n  button.btn svg{width:42%;height:42%}\n  button.btn:hover{background:rgba(255,255,255,.1)}\n  button.btn:active{transform:scale(.9)}\n  button.plus{\n    background:rgba(110,231,183,.14);\n    border-color:rgba(110,231,183,.4);\n    color:#6EE7B7;\n    width:clamp(54px,17vw,88px);height:clamp(54px,17vw,88px);\n  }\n  button.plus:hover{background:rgba(110,231,183,.22)}\n  button.plus svg{width:38%;height:38%}\n  button.btn:disabled{opacity:.3;cursor:default}\n  button.btn:disabled:active{transform:none}\n</style>\n</head>\n<body>\n<div class=\"wrap\">\n  <div class=\"head\">\n    <div class=\"label\">Water today</div>\n    <div class=\"sub\" id=\"sub\">Stay topped up</div>\n  </div>\n\n  <div class=\"ringwrap\" id=\"ringwrap\">\n    <svg class=\"ring\" viewBox=\"0 0 100 100\" aria-hidden=\"true\">\n      <defs>\n        <linearGradient id=\"mintgrad\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n          <stop offset=\"0\" stop-color=\"#6EE7B7\"/>\n          <stop offset=\"1\" stop-color=\"#3FD6A4\"/>\n        </linearGradient>\n      </defs>\n      <circle class=\"track\" cx=\"50\" cy=\"50\" r=\"44\" stroke-width=\"6\"/>\n      <circle class=\"prog\" id=\"prog\" cx=\"50\" cy=\"50\" r=\"44\" stroke-width=\"6\"\n        stroke-dasharray=\"276.46\" stroke-dashoffset=\"276.46\"/>\n    </svg>\n    <div class=\"core\">\n      <div class=\"fill\" id=\"fill\">\n        <svg viewBox=\"0 0 200 24\" preserveAspectRatio=\"none\">\n          <path class=\"wave-a\" d=\"M0 12 Q25 4 50 12 T100 12 T150 12 T200 12 V24 H0 Z\" fill=\"rgba(110,231,183,.3)\"/>\n        </svg>\n        <svg viewBox=\"0 0 200 24\" preserveAspectRatio=\"none\">\n          <path class=\"wave-b\" d=\"M0 12 Q25 20 50 12 T100 12 T150 12 T200 12 V24 H0 Z\" fill=\"rgba(110,231,183,.22)\"/>\n        </svg>\n        <div class=\"water\"></div>\n      </div>\n      <div class=\"count\">\n        <div class=\"num\" id=\"num\">0</div>\n        <div class=\"of\" id=\"of\">of 8 glasses</div>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"controls\">\n    <button class=\"btn minus\" id=\"minus\" aria-label=\"Remove a glass\">\n      <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.6\" stroke-linecap=\"round\"><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/></svg>\n    </button>\n    <button class=\"btn plus\" id=\"plus\" aria-label=\"Add a glass\">\n      <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.6\" stroke-linecap=\"round\"><line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"/><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/></svg>\n    </button>\n  </div>\n</div>\n\n<script>\nvar Vitality={_w:{},save:function(d){parent.postMessage({source:'vitality-tile',type:'save',data:d},'*')},load:function(){return new Promise(function(res){var id=Math.random().toString(36).slice(2);Vitality._w[id]=res;parent.postMessage({source:'vitality-tile',type:'load',id:id},'*')})}};\nwindow.addEventListener('message',function(e){var m=e.data;if(m&&m.source==='vitality-host'&&m.type==='load:result'&&Vitality._w[m.id]){Vitality._w[m.id](m.data);delete Vitality._w[m.id]}});\n\n(function(){\n  var CIRC=276.46; // 2*pi*44\n\n  function todayKey(){\n    var d=new Date();\n    var m=String(d.getMonth()+1).padStart(2,'0');\n    var day=String(d.getDate()).padStart(2,'0');\n    return d.getFullYear()+'-'+m+'-'+day;\n  }\n\n  var state={date:todayKey(),count:0,goal:8};\n\n  function sanitize(d){\n    var goal=8;\n    if(d&&typeof d.goal==='number'&&isFinite(d.goal)&&d.goal>0){goal=Math.round(d.goal);}\n    var s={date:todayKey(),count:0,goal:goal};\n    if(d&&typeof d==='object'){\n      if(d.date===s.date){ // same local day, keep progress\n        var c=(typeof d.count==='number'&&isFinite(d.count))?Math.round(d.count):0;\n        s.count=Math.max(0,c);\n      }\n      // different/missing date -> fresh day, count stays 0\n    }\n    return s;\n  }\n\n  var num=document.getElementById('num');\n  var ofEl=document.getElementById('of');\n  var sub=document.getElementById('sub');\n  var prog=document.getElementById('prog');\n  var fill=document.getElementById('fill');\n  var ringwrap=document.getElementById('ringwrap');\n  var minus=document.getElementById('minus');\n  var plus=document.getElementById('plus');\n\n  var DONE_MSGS=['Goal reached. Nicely done','Fully topped up','Hydrated and happy'];\n\n  function render(animatePop){\n    var goal=state.goal;\n    var count=state.count;\n    var ratio=goal>0?Math.min(1,count/goal):0;\n    var done=count>=goal&&goal>0;\n\n    num.textContent=count;\n    ofEl.textContent='of '+goal+' glasses';\n    prog.style.strokeDashoffset=(CIRC*(1-ratio)).toFixed(2);\n    // wave fills upward as ratio grows; full fill nudged slightly past for a brimming feel\n    var lift=done?-6:0;\n    fill.style.transform='translateY('+((1-ratio)*100+lift)+'%)';\n\n    if(done){\n      ringwrap.classList.add('done');\n      sub.classList.add('done');\n      sub.textContent=DONE_MSGS[Math.min(count-goal,DONE_MSGS.length-1)]||DONE_MSGS[0];\n    }else{\n      ringwrap.classList.remove('done');\n      sub.classList.remove('done');\n      var left=goal-count;\n      sub.textContent=count===0?'Stay topped up':(left+' to go');\n    }\n\n    minus.disabled=count<=0;\n\n    if(animatePop){\n      num.classList.remove('pop');\n      void num.offsetWidth;\n      num.classList.add('pop');\n      setTimeout(function(){num.classList.remove('pop');},520);\n    }\n  }\n\n  function persist(){\n    Vitality.save({date:state.date,count:state.count,goal:state.goal});\n  }\n\n  plus.addEventListener('click',function(){\n    state.count+=1;\n    render(true);\n    persist();\n  });\n  minus.addEventListener('click',function(){\n    if(state.count<=0)return;\n    state.count-=1;\n    render(true);\n    persist();\n  });\n\n  // initial paint with defaults so it never looks blank, then hydrate\n  render(false);\n\n  Vitality.load().then(function(d){\n    var loaded=sanitize(d);\n    var rolled=(d&&d.date&&d.date!==todayKey()); // crossed into a new day\n    state=loaded;\n    render(false);\n    // if we reset for a new day, or there was no saved data, write the fresh state back so it persists\n    if(rolled||!d){persist();}\n  }).catch(function(){\n    state=sanitize(null);\n    render(false);\n  });\n})();\n</script>\n</body></html>",
  "habit-streak": "<!doctype html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><style>\n*{box-sizing:border-box}\nhtml,body{height:100%}\nbody{background:transparent;color:#fff;font-family:-apple-system,BlinkMacSystemFont,'Inter','Segoe UI',sans-serif;accent-color:#6EE7B7;margin:0}\n.wrap{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;min-height:100svh;padding:clamp(12px,3.2vw,40px);gap:clamp(7px,2vw,22px);text-align:center;overflow:auto}\n.habit-row{display:flex;align-items:center;gap:6px;max-width:100%}\n.habit{background:transparent;border:none;color:#fff;font:inherit;font-size:clamp(14px,3.2vw,22px);font-weight:600;text-align:center;letter-spacing:.2px;padding:5px 8px;border-radius:10px;min-width:40px;max-width:min(82vw,360px);width:auto;outline:none;transition:background .3s cubic-bezier(.16,1,.3,1)}\n.habit:hover{background:rgba(255,255,255,.05)}\n.habit:focus{background:rgba(110,231,183,.10)}\n.edit-ic{flex:0 0 auto;opacity:.45;transition:opacity .3s cubic-bezier(.16,1,.3,1)}\n.habit-row:hover .edit-ic{opacity:.8}\n.streak-block{display:flex;flex-direction:column;align-items:center;gap:0}\n.num{font-size:clamp(40px,14vw,140px);font-weight:800;line-height:.92;letter-spacing:-2px;color:#6EE7B7;text-shadow:0 0 30px rgba(110,231,183,.28);transition:transform .5s cubic-bezier(.16,1,.3,1)}\n.num.pop{transform:scale(1.12)}\n.unit{font-size:clamp(12px,2.8vw,18px);font-weight:600;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.55)}\n.btn{appearance:none;border:none;cursor:pointer;font:inherit;font-weight:700;font-size:clamp(14px,3.4vw,19px);color:#04140d;background:#6EE7B7;border-radius:999px;padding:clamp(11px,2.6vw,18px) clamp(22px,6vw,44px);min-height:48px;display:inline-flex;align-items:center;justify-content:center;gap:9px;box-shadow:0 8px 28px rgba(110,231,183,.30);transition:transform .4s cubic-bezier(.16,1,.3,1),box-shadow .4s cubic-bezier(.16,1,.3,1),opacity .4s cubic-bezier(.16,1,.3,1)}\n.btn:hover{transform:translateY(-2px);box-shadow:0 12px 34px rgba(110,231,183,.40)}\n.btn:active{transform:translateY(0) scale(.97)}\n.done-state{display:flex;flex-direction:column;align-items:center;gap:10px}\n.done-msg{display:inline-flex;align-items:center;gap:9px;font-size:clamp(13px,3.2vw,18px);font-weight:600;color:rgba(255,255,255,.82);padding:clamp(10px,2.4vw,16px) clamp(18px,4.6vw,30px);min-height:48px;border-radius:999px;background:rgba(110,231,183,.10);border:1px solid rgba(110,231,183,.22)}\n.check{flex:0 0 auto}\n.best{display:inline-flex;align-items:center;gap:7px;font-size:clamp(11px,2.6vw,13px);font-weight:600;letter-spacing:.4px;color:rgba(255,255,255,.50)}\n.best svg{flex:0 0 auto;opacity:.7}\n@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}\n.wrap>*{animation:fadeUp .5s cubic-bezier(.16,1,.3,1) both}\n.wrap>*:nth-child(2){animation-delay:.05s}\n.wrap>*:nth-child(3){animation-delay:.1s}\n.wrap>*:nth-child(4){animation-delay:.15s}\n</style></head><body>\n<div class=\"wrap\">\n  <div class=\"habit-row\">\n    <input id=\"habit\" class=\"habit\" maxlength=\"40\" aria-label=\"Habit name\" spellcheck=\"false\"/>\n    <svg class=\"edit-ic\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#6EE7B7\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 20h9\"/><path d=\"M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z\"/></svg>\n  </div>\n  <div class=\"streak-block\">\n    <div id=\"num\" class=\"num\">0</div>\n    <div id=\"unit\" class=\"unit\">days</div>\n  </div>\n  <div id=\"action\"></div>\n  <div id=\"bestRow\" class=\"best\" hidden>\n    <svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#6EE7B7\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M5 16 3 5l5.5 4L12 4l3.5 5L21 5l-2 11Z\"/><path d=\"M5 16h14\"/></svg>\n    <span id=\"bestTxt\"></span>\n  </div>\n</div>\n<script>\nvar Vitality={_w:{},save:function(d){parent.postMessage({source:'vitality-tile',type:'save',data:d},'*')},load:function(){return new Promise(function(res){var id=Math.random().toString(36).slice(2);Vitality._w[id]=res;parent.postMessage({source:'vitality-tile',type:'load',id:id},'*')})}};\nwindow.addEventListener('message',function(e){var m=e.data;if(m&&m.source==='vitality-host'&&m.type==='load:result'&&Vitality._w[m.id]){Vitality._w[m.id](m.data);delete Vitality._w[m.id]}});\n\nfunction dateKey(d){d=d||new Date();var y=d.getFullYear(),m=('0'+(d.getMonth()+1)).slice(-2),day=('0'+d.getDate()).slice(-2);return y+'-'+m+'-'+day}\nfunction yesterdayKey(){var d=new Date();d.setDate(d.getDate()-1);return dateKey(d)}\n\nvar DEFAULTS={name:'Move my body',streak:0,lastDone:null,best:0};\nvar state=Object.assign({},DEFAULTS);\n\nfunction sanitize(d){\n  var s=Object.assign({},DEFAULTS);\n  if(d&&typeof d==='object'){\n    if(typeof d.name==='string'&&d.name.trim())s.name=d.name.slice(0,40);\n    if(typeof d.streak==='number'&&isFinite(d.streak)&&d.streak>=0)s.streak=Math.floor(d.streak);\n    if(typeof d.lastDone==='string'&&/^\\d{4}-\\d{2}-\\d{2}$/.test(d.lastDone))s.lastDone=d.lastDone;\n    if(typeof d.best==='number'&&isFinite(d.best)&&d.best>=0)s.best=Math.floor(d.best);\n  }\n  if(s.best<s.streak)s.best=s.streak;\n  return s;\n}\n\nvar habitEl=document.getElementById('habit'),numEl=document.getElementById('num'),unitEl=document.getElementById('unit'),actionEl=document.getElementById('action'),bestRow=document.getElementById('bestRow'),bestTxt=document.getElementById('bestTxt');\n\nfunction doneToday(){return state.lastDone===dateKey()}\n\nfunction render(){\n  if(document.activeElement!==habitEl)habitEl.value=state.name;\n  numEl.textContent=state.streak;\n  unitEl.textContent=state.streak===1?'day':'days';\n  actionEl.innerHTML='';\n  if(doneToday()){\n    var ds=document.createElement('div');ds.className='done-state';\n    var msg=document.createElement('div');msg.className='done-msg';\n    msg.innerHTML='<svg class=\"check\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#6EE7B7\" stroke-width=\"2.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M20 6 9 17l-5-5\"/></svg><span>Done. See you tomorrow.</span>';\n    ds.appendChild(msg);actionEl.appendChild(ds);\n  }else{\n    var b=document.createElement('button');b.className='btn';b.type='button';\n    b.innerHTML='<svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#04140d\" stroke-width=\"2.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M20 6 9 17l-5-5\"/></svg><span>Done today</span>';\n    b.addEventListener('click',markDone);\n    actionEl.appendChild(b);\n  }\n  if(state.best>0){bestRow.hidden=false;bestTxt.textContent='Best '+state.best+' '+(state.best===1?'day':'days');}\n  else{bestRow.hidden=true;}\n}\n\nfunction markDone(){\n  if(doneToday())return;\n  if(state.lastDone===yesterdayKey()){state.streak=state.streak+1;}\n  else{state.streak=1;}\n  state.lastDone=dateKey();\n  if(state.streak>state.best)state.best=state.streak;\n  Vitality.save(state);\n  render();\n  numEl.classList.remove('pop');void numEl.offsetWidth;numEl.classList.add('pop');\n}\n\nhabitEl.addEventListener('input',function(){\n  state.name=habitEl.value.slice(0,40);\n  Vitality.save(state);\n});\nhabitEl.addEventListener('blur',function(){\n  if(!state.name.trim()){state.name=DEFAULTS.name;habitEl.value=state.name;Vitality.save(state);}\n});\nhabitEl.addEventListener('keydown',function(e){if(e.key==='Enter'){e.preventDefault();habitEl.blur();}});\n\nVitality.load().then(function(d){\n  state=sanitize(d);\n  Vitality.save(state);\n  render();\n}).catch(function(){state=Object.assign({},DEFAULTS);render();});\n</script>\n</body></html>",
  "one-line-journal": "<!doctype html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><style>\n*{box-sizing:border-box}\nbody{background:transparent;color:#fff;font-family:-apple-system,BlinkMacSystemFont,'Inter','Segoe UI',sans-serif;accent-color:#6EE7B7;margin:0}\n.wrap{display:flex;flex-direction:column;gap:clamp(12px,2.5vw,18px);padding:clamp(14px,3vw,22px);max-width:640px;margin:0 auto;min-height:100%}\n.head{display:flex;align-items:center;gap:9px}\n.head svg{flex:0 0 auto}\n.title{font-size:clamp(13px,2.4vw,15px);font-weight:600;letter-spacing:.2px;color:rgba(255,255,255,.92)}\n.sub{font-size:11px;color:rgba(255,255,255,.4);margin-top:1px;font-weight:500}\n.compose{display:flex;flex-direction:column;gap:10px}\n.field{position:relative;display:flex;align-items:center}\n.input{width:100%;background:rgba(255,255,255,.045);border:1px solid rgba(255,255,255,.09);border-radius:14px;color:#fff;font:inherit;font-size:clamp(14px,2.6vw,15px);padding:14px 15px;outline:none;transition:border-color .3s cubic-bezier(.16,1,.3,1),background .3s cubic-bezier(.16,1,.3,1)}\n.input::placeholder{color:rgba(255,255,255,.32)}\n.input:focus{border-color:rgba(110,231,183,.5);background:rgba(110,231,183,.05)}\n.row{display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap}\n.count{font-size:11px;color:rgba(255,255,255,.32);font-variant-numeric:tabular-nums;transition:color .3s cubic-bezier(.16,1,.3,1)}\n.count.warn{color:#E8964A}\n.save{display:inline-flex;align-items:center;gap:7px;background:rgba(110,231,183,.14);border:1px solid rgba(110,231,183,.3);color:#6EE7B7;font:inherit;font-weight:600;font-size:13px;padding:11px 18px;border-radius:12px;cursor:pointer;transition:transform .3s cubic-bezier(.16,1,.3,1),background .3s cubic-bezier(.16,1,.3,1),opacity .3s}\n.save:hover:not(:disabled){background:rgba(110,231,183,.22)}\n.save:active:not(:disabled){transform:scale(.96)}\n.save:disabled{opacity:.4;cursor:default}\n.save.saved{background:rgba(185,163,255,.16);border-color:rgba(185,163,255,.34);color:#b9a3ff}\n.divider{height:1px;background:linear-gradient(90deg,transparent,rgba(255,255,255,.07),transparent)}\n.list{display:flex;flex-direction:column;gap:2px;list-style:none;padding:0;margin:0}\n.entry{display:flex;gap:12px;padding:12px 4px;border-bottom:1px solid rgba(255,255,255,.04);animation:rise .5s cubic-bezier(.16,1,.3,1) both}\n.entry:last-child{border-bottom:none}\n@keyframes rise{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}\n.date{flex:0 0 auto;width:clamp(46px,11vw,58px);font-size:11px;font-weight:600;color:#b9a3ff;line-height:1.35;font-variant-numeric:tabular-nums;padding-top:1px}\n.date.today{color:#6EE7B7}\n.date small{display:block;font-size:9px;font-weight:600;letter-spacing:.5px;color:rgba(255,255,255,.3);text-transform:uppercase;margin-top:1px}\n.text{flex:1;font-size:clamp(13px,2.5vw,14.5px);line-height:1.5;color:rgba(255,255,255,.86);word-break:break-word}\n.empty{display:flex;flex-direction:column;align-items:center;text-align:center;gap:10px;padding:26px 16px;color:rgba(255,255,255,.46)}\n.empty svg{opacity:.85}\n.empty p{margin:0;font-size:13px;line-height:1.5;max-width:240px}\n.empty .accent{color:#b9a3ff;font-weight:600}\n.scroll{overflow-y:auto;max-height:none}\n@media(min-height:520px){.scroll{flex:1}}\n</style></head><body>\n<div class=\"wrap\">\n  <div class=\"head\">\n    <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#6EE7B7\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M4 19.5A2.5 2.5 0 0 1 6.5 17H20\"/><path d=\"M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z\"/></svg>\n    <div>\n      <div class=\"title\">One Line a Day</div>\n      <div class=\"sub\" id=\"sub\">A single line about today</div>\n    </div>\n  </div>\n\n  <div class=\"compose\">\n    <div class=\"field\">\n      <input id=\"input\" class=\"input\" type=\"text\" maxlength=\"160\" placeholder=\"One line about today\" autocomplete=\"off\" />\n    </div>\n    <div class=\"row\">\n      <span class=\"count\" id=\"count\">0 / 160</span>\n      <button class=\"save\" id=\"save\" disabled>\n        <svg width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M5 12l5 5L20 7\"/></svg>\n        <span id=\"saveLabel\">Save line</span>\n      </button>\n    </div>\n  </div>\n\n  <div class=\"divider\"></div>\n\n  <div class=\"scroll\" id=\"scroll\"></div>\n</div>\n\n<script>\nvar Vitality={_w:{},save:function(d){parent.postMessage({source:'vitality-tile',type:'save',data:d},'*')},load:function(){return new Promise(function(res){var id=Math.random().toString(36).slice(2);Vitality._w[id]=res;parent.postMessage({source:'vitality-tile',type:'load',id:id},'*')})}};\nwindow.addEventListener('message',function(e){var m=e.data;if(m&&m.source==='vitality-host'&&m.type==='load:result'&&Vitality._w[m.id]){Vitality._w[m.id](m.data);delete Vitality._w[m.id]}});\n\nvar MAX=160;\nvar entries=[];\nvar savedTimer=null;\n\nvar input=document.getElementById('input');\nvar save=document.getElementById('save');\nvar saveLabel=document.getElementById('saveLabel');\nvar count=document.getElementById('count');\nvar scroll=document.getElementById('scroll');\nvar sub=document.getElementById('sub');\n\nfunction pad(n){return n<10?'0'+n:''+n}\nfunction todayKey(){var d=new Date();return d.getFullYear()+'-'+pad(d.getMonth()+1)+'-'+pad(d.getDate())}\n\nvar MON=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];\nfunction parseKey(k){var p=String(k).split('-');return new Date(+p[0],(+p[1]||1)-1,+p[2]||1)}\nfunction fmtDate(k){var d=parseKey(k);return{day:d.getDate(),mon:MON[d.getMonth()]}}\n\nfunction esc(s){return String(s).replace(/[&<>\"]/g,function(c){return{'&':'&amp;','<':'&lt;','>':'&gt;','\"':'&quot;'}[c]})}\n\nfunction sanitize(raw){\n  var out=[];\n  if(!raw||!Array.isArray(raw.entries)){\n    if(Array.isArray(raw)){raw={entries:raw}}else{return out}\n  }\n  for(var i=0;i<raw.entries.length;i++){\n    var en=raw.entries[i];\n    if(!en||typeof en!=='object')continue;\n    var date=typeof en.date==='string'?en.date:'';\n    var text=typeof en.text==='string'?en.text:'';\n    if(!/^\\d{4}-\\d{2}-\\d{2}$/.test(date)||!text.trim())continue;\n    out.push({date:date,text:text});\n  }\n  // newest first by date key\n  out.sort(function(a,b){return a.date<b.date?1:a.date>b.date?-1:0});\n  // de-dup by date, keep first (newest already sorted)\n  var seen={},dedup=[];\n  for(var j=0;j<out.length;j++){if(seen[out[j].date])continue;seen[out[j].date]=1;dedup.push(out[j])}\n  return dedup;\n}\n\nfunction persist(){Vitality.save({entries:entries})}\n\nfunction todayEntry(){var t=todayKey();for(var i=0;i<entries.length;i++){if(entries[i].date===t)return entries[i]}return null}\n\nfunction updateCount(){\n  var len=input.value.length;\n  count.textContent=len+' / '+MAX;\n  count.classList.toggle('warn',len>MAX-20);\n  save.disabled=input.value.trim().length===0;\n}\n\nfunction syncCompose(){\n  var te=todayEntry();\n  if(te){\n    saveLabel.textContent='Update today';\n    sub.textContent='You wrote today. Edit it any time';\n    if(!input.value)input.value=te.text;\n  }else{\n    saveLabel.textContent='Save line';\n    sub.textContent='A single line about today';\n  }\n  updateCount();\n}\n\nfunction render(){\n  scroll.innerHTML='';\n  if(entries.length===0){\n    var e=document.createElement('div');\n    e.className='empty';\n    e.innerHTML='<svg width=\"30\" height=\"30\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#b9a3ff\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 20h9\"/><path d=\"M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z\"/></svg><p>Your journal is empty. Write <span class=\"accent\">one line</span> about today to begin.</p>';\n    scroll.appendChild(e);\n    return;\n  }\n  var t=todayKey();\n  var ul=document.createElement('ul');\n  ul.className='list';\n  for(var i=0;i<entries.length;i++){\n    var en=entries[i];\n    var f=fmtDate(en.date);\n    var li=document.createElement('li');\n    li.className='entry';\n    li.style.animationDelay=(Math.min(i,8)*0.035)+'s';\n    var isToday=en.date===t;\n    li.innerHTML='<div class=\"date'+(isToday?' today':'')+'\">'+f.day+'<small>'+f.mon+'</small></div><div class=\"text\">'+esc(en.text)+'</div>';\n    ul.appendChild(li);\n  }\n  scroll.appendChild(ul);\n}\n\nfunction doSave(){\n  var text=input.value.trim();\n  if(!text)return;\n  var t=todayKey();\n  var te=todayEntry();\n  if(te){te.text=text}\n  else{entries.unshift({date:t,text:text})}\n  // ensure newest-first ordering preserved\n  entries.sort(function(a,b){return a.date<b.date?1:a.date>b.date?-1:0});\n  persist();\n  render();\n  syncCompose();\n  input.blur();\n  save.classList.add('saved');\n  if(savedTimer)clearTimeout(savedTimer);\n  savedTimer=setTimeout(function(){save.classList.remove('saved')},1400);\n}\n\ninput.addEventListener('input',updateCount);\ninput.addEventListener('keydown',function(ev){if(ev.key==='Enter'){ev.preventDefault();doSave()}});\nsave.addEventListener('click',doSave);\n\nVitality.load().then(function(d){\n  entries=sanitize(d);\n  render();\n  syncCompose();\n}).catch(function(){\n  entries=[];\n  render();\n  syncCompose();\n});\n</script>\n</body></html>",
  "mood-check": "<!doctype html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><style>\n*{box-sizing:border-box}\nbody{background:transparent;color:#fff;font-family:-apple-system,BlinkMacSystemFont,'Inter','Segoe UI',sans-serif;accent-color:#6EE7B7;margin:0;-webkit-font-smoothing:antialiased}\n.wrap{display:flex;flex-direction:column;gap:clamp(14px,4vw,26px);padding:clamp(14px,4vw,28px);max-width:560px;margin:0 auto}\n.head{display:flex;flex-direction:column;gap:4px}\n.title{font-size:clamp(15px,4.4vw,20px);font-weight:600;letter-spacing:-.01em}\n.sub{font-size:clamp(12px,3.4vw,14px);color:rgba(255,255,255,.55);font-weight:400;line-height:1.4}\n.faces{display:flex;gap:clamp(6px,2.2vw,12px);justify-content:space-between}\n.face{flex:1;aspect-ratio:1;min-width:0;min-height:44px;border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.03);border-radius:18px;padding:0;cursor:pointer;display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.5);transition:transform .5s cubic-bezier(.16,1,.3,1),background .5s cubic-bezier(.16,1,.3,1),border-color .5s cubic-bezier(.16,1,.3,1),color .5s cubic-bezier(.16,1,.3,1)}\n.face svg{width:64%;height:64%;display:block}\n.face:hover{background:rgba(255,255,255,.06);transform:translateY(-2px)}\n.face:active{transform:scale(.94)}\n.face.on{transform:translateY(-2px) scale(1.04)}\n.face:focus-visible{outline:2px solid #6EE7B7;outline-offset:2px}\n.row{display:flex;flex-direction:column;gap:9px}\n.rowlabel{font-size:clamp(10px,2.8vw,11px);text-transform:uppercase;letter-spacing:.08em;color:rgba(255,255,255,.4);font-weight:600}\n.dots{display:flex;gap:clamp(5px,2vw,10px);align-items:center}\n.day{flex:1;display:flex;flex-direction:column;align-items:center;gap:6px;min-width:0}\n.dot{width:clamp(14px,5vw,22px);height:clamp(14px,5vw,22px);border-radius:50%;background:rgba(255,255,255,.07);transition:background .5s cubic-bezier(.16,1,.3,1),box-shadow .5s cubic-bezier(.16,1,.3,1)}\n.dot.today{box-shadow:0 0 0 2px rgba(110,231,183,.5)}\n.dname{font-size:clamp(9px,2.6vw,11px);color:rgba(255,255,255,.35);font-weight:500}\n.dname.t{color:#6EE7B7}\n</style></head><body>\n<div class=\"wrap\">\n  <div class=\"head\">\n    <div class=\"title\">Today's mood</div>\n    <div class=\"sub\" id=\"sub\">Tap a face to log how you feel.</div>\n  </div>\n  <div class=\"faces\" id=\"faces\"></div>\n  <div class=\"row\">\n    <div class=\"rowlabel\">Last 7 days</div>\n    <div class=\"dots\" id=\"dots\"></div>\n  </div>\n</div>\n<script>\nvar Vitality={_w:{},save:function(d){parent.postMessage({source:'vitality-tile',type:'save',data:d},'*')},load:function(){return new Promise(function(res){var id=Math.random().toString(36).slice(2);Vitality._w[id]=res;parent.postMessage({source:'vitality-tile',type:'load',id:id},'*')})}};\nwindow.addEventListener('message',function(e){var m=e.data;if(m&&m.source==='vitality-host'&&m.type==='load:result'&&Vitality._w[m.id]){Vitality._w[m.id](m.data);delete Vitality._w[m.id]}});\n\n// warm gradient amber (low) -> mint (great), never red\nvar COLORS={1:'#E8964A',2:'#E6B25C',3:'#CFD17A',4:'#A6E08C',5:'#6EE7B7'};\nvar LABELS={1:'Low.',2:'Meh.',3:'Okay.',4:'Good.',5:'Great.'};\n\n// five distinct faces (mouth curve from frown to big smile)\nfunction faceSVG(score,active){\n  var stroke=active?'#0c0c0c':'currentColor';\n  var mouths={\n    1:'M9 16.2 Q12 13.6 15 16.2',\n    2:'M9 15.2 Q12 14.2 15 15.2',\n    3:'M9 15 L15 15',\n    4:'M9 14.2 Q12 16.6 15 14.2',\n    5:'M8.4 14 Q12 18.2 15.6 14'\n  };\n  var eyeY=score>=5?9.6:9.8;\n  return '<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"'+stroke+'\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\">'\n    +'<circle cx=\"9\" cy=\"'+eyeY+'\" r=\"0.5\" fill=\"'+stroke+'\" stroke=\"none\"/>'\n    +'<circle cx=\"15\" cy=\"'+eyeY+'\" r=\"0.5\" fill=\"'+stroke+'\" stroke=\"none\"/>'\n    +'<path d=\"'+mouths[score]+'\"/></svg>';\n}\n\nvar state={days:[],today:null};\n\nfunction localKey(d){d=d||new Date();var y=d.getFullYear(),m=String(d.getMonth()+1).padStart(2,'0'),da=String(d.getDate()).padStart(2,'0');return y+'-'+m+'-'+da;}\nfunction todayKey(){return localKey();}\nfunction dayName(d){return ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'][d.getDay()];}\n\nfunction scoreFor(key){for(var i=0;i<state.days.length;i++){if(state.days[i]&&state.days[i].date===key)return state.days[i].score;}return null;}\n\nfunction setToday(score){\n  var key=todayKey();\n  var found=false;\n  for(var i=0;i<state.days.length;i++){if(state.days[i]&&state.days[i].date===key){state.days[i].score=score;found=true;break;}}\n  if(!found)state.days.push({date:key,score:score});\n  // keep tidy: last 60 entries\n  state.days=state.days.filter(function(x){return x&&typeof x.date==='string'&&x.score>=1&&x.score<=5;});\n  if(state.days.length>60)state.days=state.days.slice(state.days.length-60);\n  state.today=score;\n  Vitality.save(state);\n  render();\n}\n\nfunction render(){\n  var tk=todayKey();\n  var cur=scoreFor(tk);\n  var faces=document.getElementById('faces');\n  faces.innerHTML='';\n  for(var s=1;s<=5;s++){\n    (function(s){\n      var b=document.createElement('button');\n      b.className='face'+(cur===s?' on':'');\n      b.setAttribute('aria-label',LABELS[s]+' mood');\n      b.setAttribute('aria-pressed',cur===s?'true':'false');\n      if(cur===s){b.style.background=COLORS[s];b.style.borderColor=COLORS[s];}\n      b.innerHTML=faceSVG(s,cur===s);\n      b.onclick=function(){setToday(s);};\n      faces.appendChild(b);\n    })(s);\n  }\n  var sub=document.getElementById('sub');\n  if(cur){sub.textContent=LABELS[cur]+' Logged for today.';}\n  else{sub.textContent='Tap a face to log how you feel.';}\n\n  var dots=document.getElementById('dots');\n  dots.innerHTML='';\n  for(var i=6;i>=0;i--){\n    var d=new Date();d.setDate(d.getDate()-i);\n    var key=localKey(d);\n    var sc=scoreFor(key);\n    var day=document.createElement('div');day.className='day';\n    var dot=document.createElement('div');dot.className='dot'+(i===0?' today':'');\n    if(sc)dot.style.background=COLORS[sc];\n    var nm=document.createElement('div');nm.className='dname'+(i===0?' t':'');nm.textContent=i===0?'Today':dayName(d);\n    day.appendChild(dot);day.appendChild(nm);dots.appendChild(day);\n  }\n}\n\nfunction hydrate(d){\n  state={days:[],today:null};\n  if(d&&typeof d==='object'){\n    if(Array.isArray(d.days)){\n      for(var i=0;i<d.days.length;i++){\n        var x=d.days[i];\n        if(x&&typeof x.date==='string'&&typeof x.score==='number'&&x.score>=1&&x.score<=5){\n          state.days.push({date:x.date,score:Math.round(x.score)});\n        }\n      }\n    }\n    var t=scoreFor(todayKey());\n    if(t)state.today=t;\n  }\n}\n\nVitality.load().then(function(d){hydrate(d);render();}).catch(function(){hydrate(null);render();});\n</script>\n</body></html>",
  "focus-timer": "<!doctype html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><style>\n*{box-sizing:border-box}\nbody{background:transparent;color:#fff;font-family:-apple-system,BlinkMacSystemFont,'Inter','Segoe UI',sans-serif;accent-color:#6EE7B7;margin:0;-webkit-font-smoothing:antialiased}\n.wrap{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:clamp(12px,3vw,22px);padding:clamp(14px,3vw,28px);min-height:100vh}\n.ringbox{position:relative;width:clamp(150px,42vw,300px);aspect-ratio:1/1;display:flex;align-items:center;justify-content:center}\nsvg.ring{position:absolute;inset:0;width:100%;height:100%;transform:rotate(-90deg)}\n.track{fill:none;stroke:rgba(255,255,255,.08);stroke-width:7}\n.prog{fill:none;stroke:#6EE7B7;stroke-width:7;stroke-linecap:round;transition:stroke .6s cubic-bezier(.16,1,.3,1),stroke-dashoffset .35s cubic-bezier(.16,1,.3,1)}\n.center{position:relative;display:flex;flex-direction:column;align-items:center;gap:3px;z-index:2;text-align:center}\n.time{font-size:clamp(28px,9vw,64px);font-weight:600;font-variant-numeric:tabular-nums;letter-spacing:-.02em;line-height:1}\n.state{font-size:clamp(10px,2.4vw,14px);letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.45);font-weight:500;min-height:1.1em;transition:color .4s cubic-bezier(.16,1,.3,1)}\n.state.done{color:#6EE7B7}\n.controls{display:flex;gap:clamp(8px,2vw,14px);flex-wrap:wrap;justify-content:center}\nbutton{font-family:inherit;font-size:clamp(12px,2.6vw,15px);font-weight:600;color:#fff;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:999px;padding:clamp(9px,1.8vw,12px) clamp(16px,3.6vw,26px);cursor:pointer;display:inline-flex;align-items:center;gap:7px;transition:transform .35s cubic-bezier(.16,1,.3,1),background .35s cubic-bezier(.16,1,.3,1),border-color .35s cubic-bezier(.16,1,.3,1),opacity .35s cubic-bezier(.16,1,.3,1);min-height:42px;-webkit-tap-highlight-color:transparent;user-select:none}\nbutton:hover{background:rgba(255,255,255,.1)}\nbutton:active{transform:scale(.95)}\nbutton.primary{background:rgba(110,231,183,.14);border-color:rgba(110,231,183,.4);color:#6EE7B7}\nbutton.primary:hover{background:rgba(110,231,183,.22)}\nbutton svg{width:15px;height:15px;display:block;flex:0 0 auto}\n.sessions{display:flex;align-items:center;gap:9px;color:rgba(255,255,255,.6);font-size:clamp(11px,2.4vw,14px);font-weight:500}\n.sessions svg{width:15px;height:15px;color:#6EE7B7;flex:0 0 auto}\n.sessions b{color:#fff;font-weight:600}\n.pulse{animation:pulse 2.4s ease-in-out infinite}\n@keyframes pulse{0%,100%{opacity:1}50%{opacity:.55}}\n.finish .prog{stroke:#6EE7B7;animation:glow 1.4s ease-out}\n@keyframes glow{0%{filter:drop-shadow(0 0 0 rgba(110,231,183,0))}40%{filter:drop-shadow(0 0 10px rgba(110,231,183,.7))}100%{filter:drop-shadow(0 0 0 rgba(110,231,183,0))}}\n</style></head><body>\n<div class=\"wrap\">\n  <div class=\"ringbox\" id=\"ringbox\">\n    <svg class=\"ring\" viewBox=\"0 0 120 120\">\n      <circle class=\"track\" cx=\"60\" cy=\"60\" r=\"54\"></circle>\n      <circle class=\"prog\" id=\"prog\" cx=\"60\" cy=\"60\" r=\"54\"></circle>\n    </svg>\n    <div class=\"center\">\n      <div class=\"time\" id=\"time\">25:00</div>\n      <div class=\"state\" id=\"state\">Ready</div>\n    </div>\n  </div>\n  <div class=\"controls\" id=\"controls\"></div>\n  <div class=\"sessions\">\n    <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M9 11l3 3L22 4\"></path><path d=\"M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11\"></path></svg>\n    <span><b id=\"count\">0</b> today</span>\n  </div>\n</div>\n<script>\nvar Vitality={_w:{},save:function(d){parent.postMessage({source:'vitality-tile',type:'save',data:d},'*')},load:function(){return new Promise(function(res){var id=Math.random().toString(36).slice(2);Vitality._w[id]=res;parent.postMessage({source:'vitality-tile',type:'load',id:id},'*')})}};\nwindow.addEventListener('message',function(e){var m=e.data;if(m&&m.source==='vitality-host'&&m.type==='load:result'&&Vitality._w[m.id]){Vitality._w[m.id](m.data);delete Vitality._w[m.id]}});\n\nvar DEFAULT_MIN=25;\nvar R=54, CIRC=2*Math.PI*R;\nvar state={date:today(),sessions:0,minutes:DEFAULT_MIN};\nvar running=false, paused=false, finished=false;\nvar remaining=DEFAULT_MIN*60;\nvar ticker=null;\n\nvar elTime=document.getElementById('time');\nvar elState=document.getElementById('state');\nvar elCount=document.getElementById('count');\nvar elProg=document.getElementById('prog');\nvar elControls=document.getElementById('controls');\nvar elRingbox=document.getElementById('ringbox');\n\nelProg.style.strokeDasharray=CIRC;\nelProg.style.strokeDashoffset=0;\n\nfunction today(){\n  var d=new Date();\n  var m=String(d.getMonth()+1).padStart(2,'0');\n  var day=String(d.getDate()).padStart(2,'0');\n  return d.getFullYear()+'-'+m+'-'+day;\n}\n\nfunction persist(){\n  Vitality.save({date:state.date,sessions:state.sessions,minutes:state.minutes});\n}\n\nfunction totalSecs(){return state.minutes*60;}\n\nfunction fmt(s){\n  if(s<0)s=0;\n  var mm=Math.floor(s/60), ss=Math.floor(s%60);\n  return String(mm).padStart(2,'0')+':'+String(ss).padStart(2,'0');\n}\n\nfunction renderRing(){\n  var tot=totalSecs();\n  var frac=tot>0?(remaining/tot):0;\n  if(frac<0)frac=0; if(frac>1)frac=1;\n  elProg.style.strokeDashoffset=CIRC*(1-frac);\n}\n\nfunction renderTime(){\n  elTime.textContent=fmt(remaining);\n}\n\nfunction renderCount(){\n  elCount.textContent=state.sessions;\n}\n\nfunction svg(path){\n  return '<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">'+path+'</svg>';\n}\nvar ICON_PLAY=svg('<polygon points=\"6 4 19 12 6 20 6 4\" fill=\"currentColor\" stroke=\"none\"></polygon>');\nvar ICON_PAUSE=svg('<rect x=\"6\" y=\"4\" width=\"4\" height=\"16\" rx=\"1\" fill=\"currentColor\" stroke=\"none\"></rect><rect x=\"14\" y=\"4\" width=\"4\" height=\"16\" rx=\"1\" fill=\"currentColor\" stroke=\"none\"></rect>');\nvar ICON_RESET=svg('<path d=\"M3 12a9 9 0 1 0 3-6.7L3 8\"></path><path d=\"M3 3v5h5\"></path>');\n\nfunction renderControls(){\n  var html='';\n  if(finished){\n    html+='<button class=\"primary\" data-act=\"again\">'+ICON_PLAY+'Again</button>';\n    html+='<button data-act=\"reset\">'+ICON_RESET+'Reset</button>';\n  } else if(!running){\n    html+='<button class=\"primary\" data-act=\"start\">'+ICON_PLAY+(paused?'Resume':'Start')+'</button>';\n    html+='<button data-act=\"reset\">'+ICON_RESET+'Reset</button>';\n  } else {\n    html+='<button data-act=\"pause\">'+ICON_PAUSE+'Pause</button>';\n    html+='<button data-act=\"reset\">'+ICON_RESET+'Reset</button>';\n  }\n  elControls.innerHTML=html;\n}\n\nfunction setState(txt,done){\n  elState.textContent=txt;\n  elState.classList.toggle('done',!!done);\n}\n\nfunction tick(){\n  remaining-=1;\n  if(remaining<=0){\n    remaining=0;\n    renderTime();renderRing();\n    complete();\n    return;\n  }\n  renderTime();renderRing();\n}\n\nfunction start(){\n  if(running)return;\n  finished=false;\n  elRingbox.classList.remove('finish');\n  running=true;paused=false;\n  setState('Focusing',false);\n  elTime.classList.remove('pulse');\n  renderControls();\n  ticker=setInterval(tick,1000);\n}\n\nfunction pause(){\n  if(!running)return;\n  running=false;paused=true;\n  clearInterval(ticker);ticker=null;\n  setState('Paused',false);\n  elTime.classList.add('pulse');\n  renderControls();\n}\n\nfunction reset(){\n  running=false;paused=false;finished=false;\n  clearInterval(ticker);ticker=null;\n  elRingbox.classList.remove('finish');\n  elTime.classList.remove('pulse');\n  remaining=totalSecs();\n  setState('Ready',false);\n  renderTime();renderRing();renderControls();\n}\n\nfunction complete(){\n  running=false;paused=false;finished=true;\n  clearInterval(ticker);ticker=null;\n  elTime.classList.remove('pulse');\n  state.sessions+=1;\n  renderCount();\n  setState('Nice. Session done.',true);\n  elRingbox.classList.add('finish');\n  renderControls();\n  persist();\n}\n\nelControls.addEventListener('click',function(e){\n  var btn=e.target.closest('button');\n  if(!btn)return;\n  var act=btn.getAttribute('data-act');\n  if(act==='start')start();\n  else if(act==='pause')pause();\n  else if(act==='reset')reset();\n  else if(act==='again'){reset();start();}\n});\n\nfunction boot(saved){\n  if(saved&&typeof saved==='object'){\n    var s=Number(saved.sessions);\n    var min=Number(saved.minutes);\n    state.minutes=(isFinite(min)&&min>0)?min:DEFAULT_MIN;\n    if(saved.date===today()){\n      state.sessions=(isFinite(s)&&s>=0)?Math.floor(s):0;\n    } else {\n      state.sessions=0;\n    }\n  }\n  state.date=today();\n  remaining=totalSecs();\n  renderTime();renderRing();renderCount();renderControls();setState('Ready',false);\n  persist();\n}\n\nVitality.load().then(boot).catch(function(){boot(null);});\n</script>\n</body></html>"
